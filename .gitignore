# Dependencies
node_modules/

# Build output
dist/

# Turbo
.turbo/

# Akash deploy state — leases (mutable, contains DSEQ + provider) and the
# ATOR probe's v3 hidden-service keypair. The secret key is sensitive — never
# commit it. The .anyone hostname is derived from the public key; if that
# directory is removed, redeploying ator-probe generates a fresh hostname.
deploy/akash/leases.json
deploy/akash/denylist.json
deploy/akash/ator-probe-keys/
deploy/akash/townhouse-keys/

# Townhouse HS local state (Phase 4 sidecar pattern). The .anyone keypair
# at infra/townhouse-hs-keys/hs/ contains the secret key — same sensitivity
# as the deploy/akash/*-keys/ dirs above. Do NOT commit. The connector YAML
# rendered with the concrete externalUrl is also operator-local state.
infra/townhouse-hs-keys/
infra/townhouse-hs-keys-relay/
docker/configs/townhouse-hs-connector.local.yaml

# Vendored external sources cloned by build scripts (e.g. Town-Frontend)
.cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local
.env.*.local
.env.publish
.env.oyster
.env.oyster.runtime
.env.sdk-e2e
.env.townhouse-dev

# Test
coverage/
**/data/*.db
# Live-smoke failure-capture log dirs (Epic 49 stories)
packages/townhouse/e2e-real-hs-logs/
packages/townhouse/e2e-49-4-logs/
# Root-level log dir for scripts/townhouse-e2e-real-hs.sh (NFR18)
e2e-real-hs-logs/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Legal documents (private, not for version control)
_bmad-output/legal/

# Misc
*.tgz
.auto-bmad-tmp/

# Python bytecode
__pycache__/
*.pyc

# Claude Code local config (exclude skills/ which are project deliverables)
.claude/*
!.claude/skills/

# MCP config
.mcp.json

# Backup files
*.backup

# Images
*.png
*.jpg
*.jpeg
!_bmad-output/branding/**/*.png
!_bmad-output/dev-signals/assets/**/*.png

# Nix build output (symlink to /nix/store result)
/result

# Generated deployment files
docker-compose-peer*.yml
genesis.env
.playwright-cli/
wallet-*.yaml
