{
  "name": "@toon-protocol/client",
  "version": "0.16.0",
  "description": "TOON client for ILP-gated Nostr publishing with multi-hop routing and payment channels",
  "license": "MIT",
  "author": "Jonathan Green",
  "repository": {
    "type": "git",
    "url": "https://github.com/toon-protocol/toon-client.git",
    "directory": "packages/client"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nostr",
    "ilp",
    "interledger",
    "toon",
    "settlement",
    "payment-channels",
    "btp",
    "micropayments",
    "nip-02"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:client": "vitest run --config vitest.e2e.config.ts tests/e2e/docker-client-*.test.ts",
    "test:e2e:client:evm": "vitest run --config vitest.e2e.config.ts tests/e2e/docker-client-evm-e2e.test.ts",
    "test:e2e:client:solana": "vitest run --config vitest.e2e.config.ts tests/e2e/docker-client-solana-e2e.test.ts",
    "test:e2e:client:mina": "vitest run --config vitest.e2e.config.ts tests/e2e/docker-client-mina-e2e.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@noble/curves": "^2.0.0",
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "@toon-protocol/core": "^2.0.0",
    "nostr-tools": "^2.20.0",
    "viem": "^2.0.0"
  },
  "optionalDependencies": {
    "@solana/web3.js": "^1.90.0",
    "@toon-protocol/mina-zkapp": "^0.1.0",
    "mina-signer": "^3.0.0",
    "o1js": "2.14.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@toon-protocol/relay": "^1.3.1",
    "@toon-protocol/sdk": "^2.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
